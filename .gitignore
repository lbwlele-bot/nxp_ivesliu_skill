# Default: ignore downloaded/heavy workspace contents.
# Keep our own lightweight docs, rules, and knowledge-entry files explicitly.
*

# Allow git metadata and this ignore file itself.
!.gitignore

# Allow selected top-level lightweight docs.
!README.md
!workspace/
!support_level/

# Keep workspace docs and local skills.
workspace/*
!workspace/AGENTS.md
!workspace/docs/
!workspace/.agents/
workspace/docs/*
!workspace/docs/README.md
!workspace/docs/architecture-construction/
workspace/docs/architecture-construction/*
!workspace/docs/architecture-construction/README.md
!workspace/docs/architecture-construction/v1/
!workspace/docs/architecture-construction/v2/
!workspace/docs/architecture-construction/v3/
workspace/docs/architecture-construction/v1/*
workspace/docs/architecture-construction/v2/*
workspace/docs/architecture-construction/v3/*
!workspace/docs/architecture-construction/v1/README.md
!workspace/docs/architecture-construction/v2/ARCHITECTURE.md
!workspace/docs/architecture-construction/v2/CONSTRUCTION.md
!workspace/docs/architecture-construction/v2/previous/
workspace/docs/architecture-construction/v2/previous/*
!workspace/docs/architecture-construction/v2/previous/ARCHITECTURE_V2.md
!workspace/docs/architecture-construction/v2/previous/CONSTRUCTION_V2.md
!workspace/docs/architecture-construction/v3/ARCHITECTURE.md
!workspace/docs/architecture-construction/v3/CONSTRUCTION.md
workspace/.agents/*
!workspace/.agents/skills/
workspace/.agents/skills/*
!workspace/.agents/skills/board-exec/
!workspace/.agents/skills/compile/
!workspace/.agents/skills/support/
!workspace/.agents/skills/understanding/
workspace/.agents/skills/board-exec/*
workspace/.agents/skills/compile/*
workspace/.agents/skills/support/*
workspace/.agents/skills/understanding/*
!workspace/.agents/skills/board-exec/SKILL.md
!workspace/.agents/skills/compile/SKILL.md
!workspace/.agents/skills/support/SKILL.md
!workspace/.agents/skills/understanding/SKILL.md
!workspace/.agents/skills/understanding/references/
!workspace/.agents/skills/understanding/references/*.md

# Under support_level, default to ignoring external downloads and heavy assets:
# image packages, SoC资料, SDK/toolchain payloads, cloned source trees, and tool binaries.
# Re-allow only our own entry docs and curated knowledge/routing files.
support_level/*
!support_level/README.md
!support_level/board_knowledge/
!support_level/code_assets/
!support_level/compile_targets/
!support_level/firmware/
