# Default: ignore everything in this heavy workspace.
*

# Allow git metadata and this ignore file itself.
!.gitignore

# Allow selected top-level lightweight docs.
!README.md
!SKILL_MIGRATION_STATUS.md
!workspace/
!support_level/

# Keep workspace docs and local skills.
workspace/*
!workspace/AGENTS.md
!workspace/skill-architecture-draft.md
!workspace/.agents/
workspace/.agents/*
!workspace/.agents/skills/
workspace/.agents/skills/*
!workspace/.agents/skills/board-exec/
!workspace/.agents/skills/compile/
!workspace/.agents/skills/support/
!workspace/.agents/skills/understanding/
workspace/.agents/skills/board-exec/*
workspace/.agents/skills/compile/*
workspace/.agents/skills/support/*
workspace/.agents/skills/understanding/*
!workspace/.agents/skills/board-exec/SKILL.md
!workspace/.agents/skills/compile/SKILL.md
!workspace/.agents/skills/support/SKILL.md
!workspace/.agents/skills/understanding/SKILL.md

