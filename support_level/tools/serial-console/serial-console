SUPPORT_ROOT = Path(__file__).resolve().parents[2]
BOARD_ROOT = SUPPORT_ROOT / "board_knowledge"
DEV_ROOT = Path("/dev")
SYS_TTY_ROOT = Path("/sys/class/tty")
PROFILE_STATES = {"verified", "partial", "unknown"}


def load_profile(board: str) -> dict[str, Any]:
    path = BOARD_ROOT / board / "serial.yaml"
    if not path.is_file():
        raise SystemExit(f"serial profile not found: {path}")
    with path.open("r", encoding="utf-8") as handle:
        data = yaml.safe_load(handle) or {}
    if not isinstance(data, dict):
        raise SystemExit(f"invalid serial profile: {path}")
    validate_profile(data, path)
    return data


def validate_profile(profile: dict[str, Any], path: Path | None = None) -> None:
    label = str(path or "<profile>")
    schema_version = int(profile.get("schema_version") or 1)
    if schema_version not in {1, 2}:
        raise SystemExit(f"unsupported serial profile schema {schema_version}: {label}")

    state = str(profile.get("profile_status") or "unknown")
    if state not in PROFILE_STATES:
        raise SystemExit(f"invalid profile_status '{state}': {label}")

    ports = profile.get("ports") or {}
    if not isinstance(ports, dict):
        raise SystemExit(f"serial profile field 'ports' must be a mapping: {label}")

    seen_orders: dict[int, str] = {}
    seen_interfaces: dict[str, str] = {}
    for role, raw_entry in ports.items():
        if not isinstance(raw_entry, dict):
            raise SystemExit(f"serial role '{role}' must be a mapping: {label}")
        order = raw_entry.get("order")
        if order is not None:
            order = int(order)
            if order < 1:
                raise SystemExit(f"serial role '{role}' has invalid order {order}: {label}")
            if order in seen_orders:
                raise SystemExit(
                    f"serial roles '{seen_orders[order]}' and '{role}' share order {order}: {label}"
                )
            seen_orders[order] = str(role)
        interface = normalize_interface(raw_entry.get("interface"))
        if raw_entry.get("interface") is not None and not interface:
            raise SystemExit(
                f"serial role '{role}' has invalid interface "
                f"'{raw_entry.get('interface')}': {label}"
            )
        if interface:
            if interface in seen_interfaces:
                raise SystemExit(
                    f"serial roles '{seen_interfaces[interface]}' and '{role}' share interface "
                    f"{interface}: {label}"
                )
            seen_interfaces[interface] = str(role)
        if order is not None and interface and int(interface[2:], 16) + 1 != order:
            raise SystemExit(
                f"serial role '{role}' order {order} does not match interface "
                f"{interface}: {label}"
            )
        port_state = str(raw_entry.get("status") or "unknown")
        if port_state not in PROFILE_STATES:
            raise SystemExit(
                f"serial role '{role}' has invalid status '{port_state}': {label}"
            )


def by_id_dir(dev_root: Path = DEV_ROOT) -> Path:
    return dev_root / "serial/by-id"


def list_by_id(dev_root: Path = DEV_ROOT) -> dict[str, str]:
    root = by_id_dir(dev_root)
    if not root.exists():
        return {}
    result: dict[str, str] = {}
    for path in sorted(root.iterdir()):
        if path.is_symlink():
            result[path.name] = str(path.resolve())
    return result


def list_serial_ttys(dev_root: Path = DEV_ROOT) -> list[str]:
    paths = list(dev_root.glob("ttyUSB*")) + list(dev_root.glob("ttyACM*"))
    return sorted(str(path) for path in paths)


def read_text(path: Path) -> str:
    try:
        return path.read_text(encoding="utf-8").strip()
    except OSError:
        return ""


def normalize_interface(value: Any) -> str:
    if value is None:
        return ""
    match = re.fullmatch(r"(?:if)?([0-9a-fA-F]{1,2})", str(value).strip())
    if not match:
        return ""
    return f"if{int(match.group(1), 16):02d}"


def interface_from_by_id(name: str) -> str:
    match = re.search(r"-if([0-9a-fA-F]{1,2})-", name)
    return normalize_interface(match.group(1)) if match else ""


def find_parent_with(start: Path, filename: str) -> Path | None:
    for candidate in (start, *start.parents):
        if (candidate / filename).is_file():
            return candidate
    return None


def discover_serial_interfaces(
    dev_root: Path = DEV_ROOT,
    sys_tty_root: Path = SYS_TTY_ROOT,
) -> list[dict[str, Any]]:
    by_id = list_by_id(dev_root)
    by_target = {str(Path(target).resolve()): name for name, target in by_id.items()}
    records: list[dict[str, Any]] = []

    for device_text in list_serial_ttys(dev_root):
        device = Path(device_text)
        canonical_device = str(device.resolve())
        by_id_name = by_target.get(canonical_device, "")
        interface = interface_from_by_id(by_id_name)
        adapter_key = ""
        usb_id = ""
        adapter_serial = ""
        product_name = ""
        sys_device = sys_tty_root / device.name / "device"

        if sys_device.exists():
            resolved = sys_device.resolve()
            interface_dir = find_parent_with(resolved, "bInterfaceNumber")
            usb_dir = find_parent_with(resolved, "idVendor")
            if interface_dir:
                raw_interface = read_text(interface_dir / "bInterfaceNumber")
                if raw_interface:
                    interface = normalize_interface(raw_interface)
            if usb_dir:
                vendor = read_text(usb_dir / "idVendor").lower()
                product = read_text(usb_dir / "idProduct").lower()
                usb_id = f"{vendor}:{product}" if vendor and product else ""
                adapter_serial = read_text(usb_dir / "serial")
                product_name = read_text(usb_dir / "product")
                adapter_key = str(usb_dir.resolve())

        if not adapter_key and by_id_name:
            adapter_key = re.sub(r"-if[0-9a-fA-F]{1,2}-port\d+$", "", by_id_name)
        if not adapter_key:
            adapter_key = f"unresolved:{device.name}"

        records.append(
            {
                "adapter_key": adapter_key,
                "adapter_serial": adapter_serial,
                "by_id": by_id_name,
                "device": str(device),
                "interface": interface,
                "product": product_name,
                "tty": device.name,
                "usb_id": usb_id,
            }
        )

    return records


def group_serial_interfaces(records: list[dict[str, Any]]) -> list[dict[str, Any]]:
    grouped: dict[str, dict[str, Any]] = {}
    for record in records:
        key = str(record["adapter_key"])
        group = grouped.setdefault(
            key,
            {
                "key": key,
                "serial": record.get("adapter_serial", ""),
                "usb_id": record.get("usb_id", ""),
                "product": record.get("product", ""),
                "interfaces": [],
            },
        )
        group["interfaces"].append(dict(record))

    result = []
    for group in grouped.values():
        group["interfaces"].sort(
            key=lambda item: (
                int(item["interface"][2:], 16) if item.get("interface") else 999,
                item["device"],
            )
        )
        for order, interface in enumerate(group["interfaces"], 1):
            interface["order"] = order
            if not interface.get("interface"):
                interface["interface"] = f"if{order - 1:02d}"
        result.append(group)
    return sorted(result, key=lambda item: item["key"])


def discover_adapter_groups() -> list[dict[str, Any]]:
    return group_serial_interfaces(discover_serial_interfaces())


def adapter_spec(profile: dict[str, Any]) -> dict[str, Any]:
    raw = profile.get("adapter") or {}
    if isinstance(raw, dict):
        return raw
    return {"name": str(raw)}


def port_interface(entry: dict[str, Any]) -> str:
    interface = normalize_interface(entry.get("interface"))
    if interface:
        return interface
    by_id = str(entry.get("by_id") or "")
    if by_id:
        return interface_from_by_id(by_id)
    order = entry.get("order")
    if order is not None:
        return f"if{int(order) - 1:02d}"
    return ""


def group_matches_profile(group: dict[str, Any], profile: dict[str, Any]) -> tuple[bool, int]:
    spec = adapter_spec(profile)
    expected_usb_id = str(spec.get("usb_id") or "").lower()
    if expected_usb_id and str(group.get("usb_id") or "").lower() != expected_usb_id:
        return False, 0

    actual_interfaces = {item["interface"] for item in group["interfaces"]}
    known_interfaces = {
        port_interface(entry)
        for entry in get_ports(profile).values()
        if port_interface(entry)
    }

    score = len(known_interfaces & actual_interfaces) * 10
    score -= len(known_interfaces - actual_interfaces) * 10
    expected_count = spec.get("interface_count")
    if expected_count is not None and len(group["interfaces"]) == int(expected_count):
        score += 5
    if expected_usb_id:
        score += 20

    known_by_ids = {
        str(entry.get("by_id"))
        for entry in get_ports(profile).values()
        if entry.get("by_id")
    }
    actual_by_ids = {str(item.get("by_id")) for item in group["interfaces"] if item.get("by_id")}
    score += len(known_by_ids & actual_by_ids) * 30
    return True, score


def select_adapter_group(
    groups: list[dict[str, Any]],
    profile: dict[str, Any] | None,
    selector: str | None,
) -> tuple[dict[str, Any] | None, str]:
    candidates = groups
    if selector:
        candidates = [
            group
            for group in groups
            if selector
            in {
                str(group.get("key") or ""),
                str(group.get("serial") or ""),
                str(group.get("usb_id") or ""),
            }
        ]
        if not candidates:
            return None, f"adapter selector did not match: {selector}"

    if profile:
        scored = []
        for group in candidates:
            matches, score = group_matches_profile(group, profile)
            if matches:
                scored.append((score, group))
        if not scored:
            return None, "no detected adapter matches the board profile"
        best_score = max(score for score, _ in scored)
        best = [group for score, group in scored if score == best_score]
        if len(best) != 1:
            return None, "multiple adapters match the board profile; pass --adapter"
        return best[0], ""

    if len(candidates) == 1:
        return candidates[0], ""
    if not candidates:
        return None, "no USB serial adapter detected"
    return None, "multiple serial adapters detected; pass --adapter"


def get_ports(profile: dict[str, Any]) -> dict[str, dict[str, Any]]:
    ports = profile.get("ports") or {}
    if not isinstance(ports, dict):
        raise SystemExit("serial profile field 'ports' must be a mapping")
    return ports


def interface_map(group: dict[str, Any] | None) -> dict[str, dict[str, Any]]:
    if not group:
        return {}
    return {str(item["interface"]): item for item in group["interfaces"]}


def profile_usb_interface_paths(
    profile: dict[str, Any],
    group: dict[str, Any],
) -> dict[str, Path]:
    adapter_path = Path(str(group.get("key") or ""))
    if not adapter_path.is_absolute():
        return {}
    result: dict[str, Path] = {}
    for entry in get_ports(profile).values():
        interface = port_interface(entry)
        if not interface:
            continue
        index = int(interface[2:], 16)
        result[interface] = adapter_path / f"{adapter_path.name}:1.{index}"
    return result


def unbound_profile_interfaces(
    profile: dict[str, Any],
    group: dict[str, Any],
) -> dict[str, Path]:
    return {
        interface: path
        for interface, path in profile_usb_interface_paths(profile, group).items()
        if path.is_dir() and not (path / "driver").exists()
    }


def bound_usb_driver(group: dict[str, Any]) -> Path | None:
    adapter_path = Path(str(group.get("key") or ""))
    if not adapter_path.is_absolute():
        return None
    for interface_path in sorted(adapter_path.glob(f"{adapter_path.name}:1.*")):
        driver_link = interface_path / "driver"
        if driver_link.exists():
            return driver_link.resolve()
    return None


def resolve_device(
    profile: dict[str, Any],
    role: str | None,
    device: str | None,
    *,
    group: dict[str, Any] | None = None,
    require_present: bool = False,
) -> str:
    if device:
        if require_present and not Path(device).exists():
            raise SystemExit(f"serial device not present: {device}")
        return device
    if not role:
        raise SystemExit("pass --role or --device")
    ports = get_ports(profile)
    if role not in ports:
        known = ", ".join(sorted(ports)) or "<none>"
        raise SystemExit(f"unknown role '{role}'. known roles: {known}")

    entry = ports[role] or {}
    by_id = entry.get("by_id")
    if by_id:
        candidate = by_id_dir() / by_id
        if candidate.exists():
            return str(candidate)

    if group is None:
        detected_groups = discover_adapter_groups()
        group, _ = select_adapter_group(detected_groups, profile, None)
    interface = port_interface(entry)
    detected = interface_map(group).get(interface)
    if detected:
        detected_by_id = detected.get("by_id")
        if detected_by_id:
            candidate = by_id_dir() / str(detected_by_id)
            if candidate.exists():
                return str(candidate)
        return str(detected["device"])

    tty_path = entry.get("tty")
    if tty_path and (not require_present or Path(str(tty_path)).exists()):
        return str(tty_path)

    if require_present:
        expected = interface or by_id or tty_path or "<unmapped>"
        raise SystemExit(f"serial role '{role}' is not present; expected {expected}")
    raise SystemExit(f"role '{role}' has no by_id or tty mapping")


def build_discovery_profile(group: dict[str, Any]) -> dict[str, Any]:
    ports: dict[str, dict[str, Any]] = {}
    for item in group["interfaces"]:
        role = f"port{int(item['order'])}"
        ports[role] = {
            "order": int(item["order"]),
            "interface": item["interface"],
            "by_id": item.get("by_id") or None,
            "tty": item["device"],
            "description": "Discovered port; role is not known",
            "default_capture": True,
            "required": True,
            "status": "unknown",
        }
    return {
        "schema_version": 2,
        "board": "unclassified",
        "profile_status": "unknown",
        "adapter": {
            "name": group.get("product") or "discovered USB serial adapter",
            "usb_id": group.get("usb_id") or "",
            "interface_count": len(group["interfaces"]),
        },
        "baudrate": 115200,
        "format": "8N1",
        "prefer_by_id": True,
        "ports": ports,
    }


def default_capture_roles(profile: dict[str, Any]) -> list[str]:
    ports = get_ports(profile)
    explicit = [
        str(role)
        for role, entry in ports.items()
        if bool(entry.get("default_capture"))
    ]
    if explicit:
        return sorted(explicit, key=lambda role: int(ports[role].get("order") or 999))

    configured = profile.get("default_capture_roles")
    if isinstance(configured, list) and configured:
        return [str(role) for role in configured if str(role) in ports]

    preferred = [role for role in ("m4", "a-core", "linux", "scfw") if role in ports]
    if preferred:
        return preferred
    return [
        role
        for role, entry in sorted(
            ports.items(),
            key=lambda item: int(item[1].get("order") or 999),
        )
        if role != "first-com"
    ]


def probe_profile(
    profile: dict[str, Any],
    group: dict[str, Any] | None,
) -> dict[str, Any]:
    result: dict[str, Any] = {
        "profile_status": str(profile.get("profile_status") or "unknown"),
        "adapter": group,
        "ports": [],
        "errors": [],
        "warnings": [],
    }
    if group is None:
        result["errors"].append("no matching serial adapter")
        for role, entry in get_ports(profile).items():
            result["ports"].append(
                {
                    "role": role,
                    "order": entry.get("order"),
                    "interface": port_interface(entry),
                    "device": "",
                    "present": False,
                    "required": bool(entry.get("required")),
                    "status": str(entry.get("status") or "unknown"),
                }
            )
        return result

    spec = adapter_spec(profile)
    expected_count = spec.get("interface_count")
    actual_count = len(group["interfaces"])
    if expected_count is not None and actual_count != int(expected_count):
        result["errors"].append(
            f"adapter interface count mismatch: expected {expected_count}, detected {actual_count}; "
            "wait for udev, inspect driver binding, then re-probe"
        )
        unbound = sorted(unbound_profile_interfaces(profile, group))
        if unbound:
            result["warnings"].append(
                "physical USB interfaces exist but have no serial driver: "
                + ", ".join(unbound)
                + "; run serial-console recover with sudo"
            )

    detected = interface_map(group)
    for role, entry in get_ports(profile).items():
        interface = port_interface(entry)
        actual = detected.get(interface)
        required = bool(entry.get("required"))
        row = {
            "role": role,
            "order": entry.get("order"),
            "interface": interface,
            "device": actual.get("device", "") if actual else "",
            "by_id": actual.get("by_id", "") if actual else "",
            "present": bool(actual),
            "required": required,
            "default_capture": bool(entry.get("default_capture")),
            "status": str(entry.get("status") or "unknown"),
            "log_sources": entry.get("log_sources") or [],
        }
        result["ports"].append(row)
        if required and not actual:
            result["errors"].append(f"required role '{role}' is missing ({interface or 'unmapped'})")
        elif not actual:
            result["warnings"].append(f"known role '{role}' is not present")

    if result["profile_status"] != "verified":
        result["warnings"].append(
            f"profile is {result['profile_status']}; unmapped interfaces must not be assigned a role"
        )
    return result


def profile_baud(profile: dict[str, Any], baud: int | None) -> int:
    return int(baud or profile.get("baudrate") or 115200)


def open_serial(device: str, baud: int, timeout: float) -> serial.Serial:
    return serial.Serial(
        port=device,
        baudrate=baud,
        bytesize=serial.EIGHTBITS,
        parity=serial.PARITY_NONE,
        stopbits=serial.STOPBITS_ONE,
        timeout=timeout,
        xonxoff=False,
        rtscts=False,
        dsrdtr=False,
    )


def append_log(log_path: str | None, data: bytes) -> None:
    if not log_path or not data:
        return
    path = Path(log_path)
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("ab") as handle:
        handle.write(data)


def emit(data: bytes) -> None:
    if not data:
        return
    sys.stdout.buffer.write(data)
    sys.stdout.buffer.flush()


def touch_log(log_path: str | None) -> None:
    if not log_path:
        return
    path = Path(log_path)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.touch(exist_ok=True)


def capture_role_loop(
    *,
    profile: dict[str, Any],
    role: str,
    device: str | None,
    group: dict[str, Any] | None,
    baud: int,
    log_path: str | None,
    timeout: float,
    read_timeout: float,
    chunk_size: int,
    reconnect: bool,
    reconnect_interval: float,
    tee: bool,
    expect_data: bool,
    initial_serial: serial.Serial | None = None,
    start_event: threading.Event | None = None,
    stop_event: threading.Event | None = None,
) -> dict[str, Any]:
    started = time.strftime("%Y-%m-%dT%H:%M:%S%z")
    result: dict[str, Any] = {
        "role": role,
        "log": log_path,
        "started": started,
        "ended": "",
        "opened_at": "",
        "first_byte_at": "",
        "bytes": 0,
        "opens": 0,
        "disconnects": 0,
        "reconnects": 0,
        "status": 0,
        "state": "starting",
        "expect_data": expect_data,
        "connected_at_end": False,
        "last_device": "",
        "last_error": "",
    }
    touch_log(log_path)
    ser = initial_serial
    if ser is not None:
        result["opens"] = 1
        result["opened_at"] = time.strftime("%Y-%m-%dT%H:%M:%S%z")
        result["last_device"] = str(getattr(ser, "port", device) or device or "")

    if start_event is not None:
        start_event.wait()
    deadline = time.monotonic() + timeout

    while time.monotonic() < deadline and not (
        stop_event is not None and stop_event.is_set()
    ):
        if ser is None:
            selected = resolve_device(profile, role, device, group=group)
            result["last_device"] = selected
            is_reconnect = bool(result["opens"] or result["last_error"])
            if is_reconnect:
                result["reconnects"] += 1
            try:
                ser = open_serial(selected, baud, read_timeout)
                result["opens"] += 1
                if not result["opened_at"]:
                    result["opened_at"] = time.strftime("%Y-%m-%dT%H:%M:%S%z")
                if is_reconnect:
                    append_log(
                        log_path,
                        f"[serial-console reconnected: {selected}]\n".encode(),
                    )
            except (serial.SerialException, OSError) as exc:
                result["last_error"] = str(exc)
                if not reconnect:
                    result["status"] = 1
                    break
                time.sleep(reconnect_interval)
                continue

        try:
            data = ser.read(chunk_size)
            if data:
                if not result["first_byte_at"]:
                    result["first_byte_at"] = time.strftime("%Y-%m-%dT%H:%M:%S%z")
                result["bytes"] += len(data)
                append_log(log_path, data)
                if tee:
                    emit(data)
        except (serial.SerialException, OSError) as exc:
            result["last_error"] = str(exc)
            result["disconnects"] += 1
            append_log(log_path, f"\n[serial-console disconnect: {exc}]\n".encode())
            try:
                ser.close()
            except (serial.SerialException, OSError):
                pass
            ser = None
            if not reconnect:
                result["status"] = 1
                break

    if ser is not None:
        result["connected_at_end"] = True
        try:
            ser.close()
        except (serial.SerialException, OSError) as exc:
            result["last_error"] = str(exc)
            result["connected_at_end"] = False

    if result["opens"] == 0:
        result["state"] = "not-opened"
        result["status"] = 1
    elif not result["connected_at_end"]:
        result["state"] = "disconnected"
        result["status"] = 1
    elif result["bytes"] == 0:
        result["state"] = "empty"
        result["status"] = 2 if expect_data else 0
    else:
        result["state"] = "data"
    result["ended"] = time.strftime("%Y-%m-%dT%H:%M:%S%z")
    return result


def cmd_list(args: argparse.Namespace) -> int:
    profile = load_profile(args.board) if args.board else {}
    by_id = list_by_id()
    serial_ttys = list_serial_ttys()
    groups = discover_adapter_groups()

    print("by-id:")
    for name, target in by_id.items():
        print(f"  {name} -> {target}")
    if not by_id:
        print("  <none>")

    print("serial devices:")
    for path in serial_ttys:
        print(f"  {path}")
    if not serial_ttys:
        print("  <none>")

    if profile:
        print(f"board: {args.board}")
        print(f"profile_status: {profile.get('profile_status', 'unknown')}")
        print(f"baudrate: {profile_baud(profile, args.baud)}")
        group, error = select_adapter_group(groups, profile, None)
        detected = interface_map(group)
        for role, entry in get_ports(profile).items():
            interface = port_interface(entry)
            actual = detected.get(interface)
            device = actual["device"] if actual else str(entry.get("tty") or "<missing>")
            desc = entry.get("description", "")
            present = "present" if actual else "missing"
            print(
                f"  {role}: {interface or '?'} {device} [{present}]"
                + (f" ({desc})" if desc else "")
            )
        if error:
            print(f"profile match: {error}")
    return 0


def print_adapter_groups(groups: list[dict[str, Any]]) -> None:
    print(f"detected adapters: {len(groups)}")
    for index, group in enumerate(groups, 1):
        identity = group.get("serial") or group.get("key")
        print(
            f"  [{index}] {group.get('usb_id') or 'usb-id-unknown'} "
            f"{group.get('product') or 'USB serial adapter'} "
            f"interfaces={len(group['interfaces'])} id={identity}"
        )
        for interface in group["interfaces"]:
            by_id = interface.get("by_id") or "<none>"
            print(
                f"      order={interface['order']} {interface['interface']} "
                f"{interface['device']} by-id={by_id}"
            )


def cmd_probe(args: argparse.Namespace) -> int:
    groups = discover_adapter_groups()
    print_adapter_groups(groups)
    profile = load_profile(args.board) if args.board else None

    if not profile:
        if args.adapter:
            group, error = select_adapter_group(groups, None, args.adapter)
            if error:
                print(f"probe error: {error}", file=sys.stderr)
                return 1
            print(f"selected adapter: {group['key']}")
        return 0 if groups else 1

    group, selection_error = select_adapter_group(groups, profile, args.adapter)
    result = probe_profile(profile, group)
    if selection_error:
        result["errors"] = [selection_error]

    print(f"board: {args.board}")
    print(f"profile_status: {result['profile_status']}")
    if group:
        print(f"selected adapter: {group['key']}")
    for port in result["ports"]:
        flags = []
        if port.get("required"):
            flags.append("required")
        if port.get("default_capture"):
            flags.append("default-capture")
        flags.append(str(port.get("status") or "unknown"))
        sources = ",".join(str(item) for item in port.get("log_sources") or [])
        print(
            f"  {port['role']}: order={port.get('order') or '?'} "
            f"{port.get('interface') or '?'} "
            f"{port.get('device') or '<missing>'} "
            f"[{','.join(flags)}]"
            + (f" logs={sources}" if sources else "")
        )
    for warning in result["warnings"]:
        print(f"warning: {warning}")
    for error in result["errors"]:
        print(f"error: {error}", file=sys.stderr)
    return 1 if result["errors"] else 0


def cmd_recover(args: argparse.Namespace) -> int:
    if os.geteuid() != 0:
        print(
            "recover error: run this subcommand with sudo -n",
            file=sys.stderr,
        )
        return 1

    profile = load_profile(args.board)
    groups = discover_adapter_groups()
    group, error = select_adapter_group(groups, profile, args.adapter)
    if error:
        print(f"recover error: {error}", file=sys.stderr)
        return 1

    unbound = unbound_profile_interfaces(profile, group)
    if not unbound:
        print("recover: no unbound profile interfaces")
        return 0

    driver = bound_usb_driver(group)
    if driver is None or not (driver / "bind").exists():
        print("recover error: cannot identify the sibling USB serial driver", file=sys.stderr)
        return 1

    status = 0
    for interface, interface_path in sorted(unbound.items()):
        try:
            (driver / "bind").write_text(interface_path.name, encoding="ascii")
            print(f"recover: bound {interface} ({interface_path.name}) to {driver.name}")
        except OSError as exc:
            print(f"recover error: failed to bind {interface}: {exc}", file=sys.stderr)
            status = 1

    subprocess.run(["udevadm", "settle"], check=False)
    return status


def stty_device(device: str, baud: int) -> tuple[int, str]:
    cmd = [
        "stty",
        "-F",
        device,
        str(baud),
        "cs8",
        "-cstopb",
        "-parenb",
        "-crtscts",
        "-ixon",
        "-ixoff",
        "raw",
        "-echo",
    ]
    proc = subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
    return proc.returncode, proc.stdout.strip()


def stop_modemmanager() -> int:
    proc = subprocess.run(
        ["sudo", "-n", "systemctl", "stop", "ModemManager"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    print(f"ModemManager stop: exit={proc.returncode}")
    if proc.stdout.strip():
        print(proc.stdout.strip())
    return int(proc.returncode)


def cmd_prepare(args: argparse.Namespace) -> int:
    profile = load_profile(args.board)
    baud = profile_baud(profile, args.baud)
    if args.stop_modemmanager:
        if stop_modemmanager():
            return 1

    ports = get_ports(profile)
    roles = args.role or [
        role
        for role, _ in sorted(
            ports.items(),
            key=lambda item: int(item[1].get("order") or 999),
        )
    ]
    groups = discover_adapter_groups()
    group, error = select_adapter_group(groups, profile, args.adapter)
    if error:
        print(f"prepare error: {error}", file=sys.stderr)
        return 1
    status = 0
    for role in roles:
        device = resolve_device(profile, role, None, group=group, require_present=True)
        code, output = stty_device(device, baud)
        print(f"{role}: {device}: stty exit={code}")
        if output:
            print(output)
        status = status or code
    return status


